<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>

    <AssemblyName>MouseFinder</AssemblyName>
    <RootNamespace>MouseFinder</RootNamespace>
    <Version>1.0.0</Version>

    <!-- Ensure correct handling of paths with non-ASCII characters (e.g. Chinese) -->
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <Authors>MouseFinder</Authors>
    <Description>A lightweight mouse cursor finder tool for Windows</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Drawing.Common" Version="8.0.0" />
  </ItemGroup>

</Project>
